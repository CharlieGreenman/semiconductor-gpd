    {
      "name": "geometry_dimensions",
      "section": "pre_run_sample_state",
      "requirement": "REQUIRED",
      "data_type": "string",
      "invalidation_rule_ref": null,
      "notes": "Length x width x thickness in micrometers"
    },
    {
      "name": "geometry_mass_estimate_mg",
      "section": "pre_run_sample_state",
      "requirement": "OPTIONAL",
      "data_type": "number",
      "invalidation_rule_ref": null,
      "notes": "If measurable at 50-80 um scale"
    },
    {
      "name": "ambient_tc_baseline_zero_resistance_k",
      "section": "pre_run_sample_state",
      "requirement": "REQUIRED",
      "data_type": "number_or_null",
      "invalidation_rule_ref": null,
