{
  "checklist_version": "1.0",
  "date": "2026-03-29",
  "purpose": "Per-run logging form for Hg1223 PQP independent reproduction campaign",
  "assert_convention": "units=SI-derived (K, GPa), room_temperature=300 K, tc_definition=zero-resistance unless onset explicitly labeled, evidence_tiers=T0-T3 per Phase 20, handling_classes=H0-H3 per Phase 19",
  "requirement_levels": {
    "REQUIRED": "Run is T0 (invalid) without this field",
    "CONDITIONAL": "Required only for specific handling classes or stages",
    "OPTIONAL": "Informational; does not affect evidence tier"
  },
  "required_fields": [
    {
      "name": "sample_id",
      "section": "pre_run_sample_state",
      "requirement": "REQUIRED",
      "data_type": "string",
      "format": "[GROUP]-S-[SEQ]",
      "invalidation_rule_ref": null,
      "notes": "Unique per sample"
    },
    {
      "name": "run_id",
      "section": "pre_run_sample_state",
      "requirement": "REQUIRED",
      "data_type": "string",
      "format": "[GROUP]-[DATE]-[CONDITION_ID]-[SEQ]",
      "invalidation_rule_ref": null,
      "notes": "Unique per run"
    },
    {
      "name": "sample_class",
      "section": "pre_run_sample_state",
      "requirement": "REQUIRED",
      "data_type": "string",
      "invalidation_rule_ref": 3,
      "notes": "Source batch identifier; enables sample-state-dependence detection"
    },
    {
      "name": "oxygen_history_class",
      "section": "pre_run_sample_state",
      "requirement": "REQUIRED",
      "data_type": "string",
      "invalidation_rule_ref": 3,
      "notes": "Delta value if measured, or qualitative annealing history"
