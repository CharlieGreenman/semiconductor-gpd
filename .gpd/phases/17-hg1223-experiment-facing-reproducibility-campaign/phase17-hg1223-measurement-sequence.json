    },
    {
      "step": 12,
      "stage": "room_temperature_stress",
      "required_measurements": ["293k_excursion_transport"]
    }
  ],
  "stage_boundaries": [
    "creation_and_recording",
    "pre_retrieval_retention",
    "retrieval_and_ex_dac_characterization",
    "room_temperature_stress"
  ],
  "required_measurements": {
    "transport_steps": [2, 4, 5, 6, 7, 9, 12],
