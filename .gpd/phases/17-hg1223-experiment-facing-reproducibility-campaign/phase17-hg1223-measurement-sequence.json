      "required_measurements": ["in_dac_transport", "target_tc_confirmation"]
    },
    {
      "step": 3,
      "stage": "quench_event",
      "required_measurements": ["pq", "tq", "vq_release_trace"]
    },
    {
      "step": 4,
      "stage": "immediate_retained_state_check",
      "required_measurements": ["ambient_pressure_cryogenic_transport"]
    },
    {
      "step": 5,
      "stage": "cryogenic_hold",
      "required_measurements": ["24h_checkpoint", "72h_checkpoint"]
    },
    {
      "step": 6,
