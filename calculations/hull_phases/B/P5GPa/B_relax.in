! CONVENTION: PBEsol, ONCV PseudoDojo, pressure in kbar = GPa*10
! Target pressure: 5 GPa = 50.0 kbar
! ecutwfc = 80 Ry, ecutrho = 320 Ry
! Generated by screening/qe_templates.py
&CONTROL
  calculation  = 'vc-relax'
  prefix       = 'B'
  outdir       = './tmp'
  pseudo_dir   = './pseudo'
  tprnfor      = .true.
  tstress      = .true.
  forc_conv_thr = 1.0d-4
  etot_conv_thr = 1.0d-6
/

&SYSTEM
  ibrav        = 0
  nat          = 2
  ntyp         = 1
  ecutwfc      = 80
  ecutrho      = 320
  input_dft    = 'pbesol'
  occupations  = 'smearing'
  smearing     = 'mv'
  degauss      = 0.02
/

&ELECTRONS
  conv_thr     = 1.0d-8
  mixing_beta  = 0.3
/

&IONS
  ion_dynamics = 'bfgs'
/

&CELL
  cell_dynamics = 'bfgs'
  press         = 50.0
  press_conv_thr = 0.5
/

ATOMIC_SPECIES
  B       10.8100  B.pbesol-n-oncvpsp-pd.UPF

ATOMIC_POSITIONS crystal
  B        0.3530000000     0.3530000000     0.3530000000
  B        0.6470000000     0.6470000000     0.6470000000

K_POINTS automatic
  6 6 6  0 0 0

CELL_PARAMETERS angstrom
      2.5285000000     1.4598301556     4.1886666667
     -2.5285000000     1.4598301556     4.1886666667
     -0.0000000000    -2.9196603113     4.1886666667
