! CONVENTION: PBEsol, ONCV PseudoDojo, pressure in kbar = GPa*10
! Target pressure: 10 GPa = 100.0 kbar
! ecutwfc = 100 Ry, ecutrho = 400 Ry
! Generated by screening/qe_templates.py
&CONTROL
  calculation  = 'vc-relax'
  prefix       = 'Ir'
  outdir       = './tmp'
  pseudo_dir   = './pseudo'
  tprnfor      = .true.
  tstress      = .true.
  forc_conv_thr = 1.0d-4
  etot_conv_thr = 1.0d-6
/

&SYSTEM
  ibrav        = 0
  nat          = 1
  ntyp         = 1
  ecutwfc      = 100
  ecutrho      = 400
  input_dft    = 'pbesol'
  occupations  = 'smearing'
  smearing     = 'mv'
  degauss      = 0.02
/

&ELECTRONS
  conv_thr     = 1.0d-8
  mixing_beta  = 0.3
/

&IONS
  ion_dynamics = 'bfgs'
/

&CELL
  cell_dynamics = 'bfgs'
  press         = 100.0
  press_conv_thr = 0.5
/

ATOMIC_SPECIES
  Ir     192.2170  Ir.pbesol-spn-oncvpsp-pd.UPF

ATOMIC_POSITIONS crystal
  Ir       0.0000000000     0.0000000000     0.0000000000

K_POINTS automatic
  12 12 12  0 0 0

CELL_PARAMETERS angstrom
      0.0000000000     1.9195000000     1.9195000000
      1.9195000000     0.0000000000     1.9195000000
      1.9195000000     1.9195000000     0.0000000000
