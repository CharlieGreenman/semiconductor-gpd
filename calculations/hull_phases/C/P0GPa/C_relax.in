! CONVENTION: PBEsol, ONCV PseudoDojo, pressure in kbar = GPa*10
! Target pressure: 0 GPa = 0.0 kbar
! ecutwfc = 80 Ry, ecutrho = 320 Ry
! Generated by screening/qe_templates.py
&CONTROL
  calculation  = 'vc-relax'
  prefix       = 'C'
  outdir       = './tmp'
  pseudo_dir   = './pseudo'
  tprnfor      = .true.
  tstress      = .true.
  forc_conv_thr = 1.0d-4
  etot_conv_thr = 1.0d-6
/

&SYSTEM
  ibrav        = 0
  nat          = 2
  ntyp         = 1
  ecutwfc      = 80
  ecutrho      = 320
  input_dft    = 'pbesol'
  occupations  = 'smearing'
  smearing     = 'mv'
  degauss      = 0.02
/

&ELECTRONS
  conv_thr     = 1.0d-8
  mixing_beta  = 0.3
/

&IONS
  ion_dynamics = 'bfgs'
/

&CELL
  cell_dynamics = 'bfgs'
  press         = 0.0
  press_conv_thr = 0.5
/

ATOMIC_SPECIES
  C       12.0110  C.pbesol-n-oncvpsp-pd.UPF

ATOMIC_POSITIONS crystal
  C        0.0000000000     0.0000000000     0.0000000000
  C        0.2500000000     0.2500000000     0.2500000000

K_POINTS automatic
  12 12 12  0 0 0

CELL_PARAMETERS angstrom
      0.0000000000     1.7835000000     1.7835000000
      1.7835000000     0.0000000000     1.7835000000
      1.7835000000     1.7835000000     0.0000000000
