! CONVENTION: PBEsol, ONCV PseudoDojo, pressure in kbar = GPa*10
! Target pressure: 50 GPa = 500.0 kbar
! ecutwfc = 80 Ry, ecutrho = 320 Ry
! Generated by screening/qe_templates.py
&CONTROL
  calculation  = 'vc-relax'
  prefix       = 'RbInH3'
  outdir       = './tmp'
  pseudo_dir   = './pseudo'
  tprnfor      = .true.
  tstress      = .true.
  forc_conv_thr = 1.0d-4
  etot_conv_thr = 1.0d-6
/

&SYSTEM
  ibrav        = 0
  nat          = 5
  ntyp         = 3
  ecutwfc      = 80
  ecutrho      = 320
  input_dft    = 'pbesol'
  occupations  = 'smearing'
  smearing     = 'mv'
  degauss      = 0.02
/

&ELECTRONS
  conv_thr     = 1.0d-8
  mixing_beta  = 0.3
/

&IONS
  ion_dynamics = 'bfgs'
/

&CELL
  cell_dynamics = 'bfgs'
  press         = 500.0
  press_conv_thr = 0.5
/

ATOMIC_SPECIES
  H        1.0080  H.pbesol-n-oncvpsp-pd.UPF
  In     114.8180  In.pbesol-dn-oncvpsp-pd.UPF
  Rb      85.4678  Rb.pbesol-spn-oncvpsp-pd.UPF

ATOMIC_POSITIONS crystal
  Rb       0.0000000000     0.0000000000     0.0000000000
  In       0.5000000000     0.5000000000     0.5000000000
  H        0.5000000000     0.5000000000     0.0000000000
  H        0.5000000000     0.0000000000     0.5000000000
  H        0.0000000000     0.5000000000     0.5000000000

K_POINTS automatic
  8 8 8  0 0 0

CELL_PARAMETERS angstrom
      3.7500000000     0.0000000000     0.0000000000
      0.0000000000     3.7500000000     0.0000000000
      0.0000000000     0.0000000000     3.7500000000
