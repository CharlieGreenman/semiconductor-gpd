! CONVENTION: PBEsol, ONCV PseudoDojo, pressure in kbar = GPa*10
! Target pressure: 10 GPa = 100.0 kbar
! ecutwfc = 80 Ry, ecutrho = 320 Ry
! Generated by screening/qe_templates.py
&CONTROL
  calculation  = 'vc-relax'
  prefix       = 'Pb'
  outdir       = './tmp'
  pseudo_dir   = './pseudo'
  tprnfor      = .true.
  tstress      = .true.
  forc_conv_thr = 1.0d-4
  etot_conv_thr = 1.0d-6
/

&SYSTEM
  ibrav        = 0
  nat          = 1
  ntyp         = 1
  ecutwfc      = 80
  ecutrho      = 320
  input_dft    = 'pbesol'
  occupations  = 'smearing'
  smearing     = 'mv'
  degauss      = 0.02
/

&ELECTRONS
  conv_thr     = 1.0d-8
  mixing_beta  = 0.3
/

&IONS
  ion_dynamics = 'bfgs'
/

&CELL
  cell_dynamics = 'bfgs'
  press         = 100.0
  press_conv_thr = 0.5
/

ATOMIC_SPECIES
  Pb     207.2000  Pb.pbesol-dn-oncvpsp-pd.UPF

ATOMIC_POSITIONS crystal
  Pb       0.0000000000     0.0000000000     0.0000000000

K_POINTS automatic
  10 10 10  0 0 0

CELL_PARAMETERS angstrom
      0.0000000000     2.4750000000     2.4750000000
      2.4750000000     0.0000000000     2.4750000000
      2.4750000000     2.4750000000     0.0000000000
