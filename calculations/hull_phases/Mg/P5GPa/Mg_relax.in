! CONVENTION: PBEsol, ONCV PseudoDojo, pressure in kbar = GPa*10
! Target pressure: 5 GPa = 50.0 kbar
! ecutwfc = 80 Ry, ecutrho = 320 Ry
! Generated by screening/qe_templates.py
&CONTROL
  calculation  = 'vc-relax'
  prefix       = 'Mg'
  outdir       = './tmp'
  pseudo_dir   = './pseudo'
  tprnfor      = .true.
  tstress      = .true.
  forc_conv_thr = 1.0d-4
  etot_conv_thr = 1.0d-6
/

&SYSTEM
  ibrav        = 0
  nat          = 2
  ntyp         = 1
  ecutwfc      = 80
  ecutrho      = 320
  input_dft    = 'pbesol'
  occupations  = 'smearing'
  smearing     = 'mv'
  degauss      = 0.02
/

&ELECTRONS
  conv_thr     = 1.0d-8
  mixing_beta  = 0.3
/

&IONS
  ion_dynamics = 'bfgs'
/

&CELL
  cell_dynamics = 'bfgs'
  press         = 50.0
  press_conv_thr = 0.5
/

ATOMIC_SPECIES
  Mg      24.3050  Mg.pbesol-spn-oncvpsp-pd.UPF

ATOMIC_POSITIONS crystal
  Mg       0.3333333333     0.6666666667     0.2500000000
  Mg       0.6666666667     0.3333333333     0.7500000000

K_POINTS automatic
  10 10 6  0 0 0

CELL_PARAMETERS angstrom
      3.2090000000     0.0000000000     0.0000000000
     -1.6045000000     2.7790755207     0.0000000000
      0.0000000000     0.0000000000     5.2110000000
