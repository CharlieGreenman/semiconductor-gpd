! CONVENTION: PBEsol, ONCV PseudoDojo, pressure in kbar = GPa*10
! Target pressure: 10 GPa = 100.0 kbar
! ecutwfc = 100 Ry, ecutrho = 400 Ry
! Generated by screening/qe_templates.py
&CONTROL
  calculation  = 'vc-relax'
  prefix       = 'Mg2IrH6'
  outdir       = './tmp'
  pseudo_dir   = './pseudo'
  tprnfor      = .true.
  tstress      = .true.
  forc_conv_thr = 1.0d-4
  etot_conv_thr = 1.0d-6
/

&SYSTEM
  ibrav        = 0
  nat          = 9
  ntyp         = 3
  ecutwfc      = 100
  ecutrho      = 400
  input_dft    = 'pbesol'
  occupations  = 'smearing'
  smearing     = 'mv'
  degauss      = 0.02
/

&ELECTRONS
  conv_thr     = 1.0d-8
  mixing_beta  = 0.3
/

&IONS
  ion_dynamics = 'bfgs'
/

&CELL
  cell_dynamics = 'bfgs'
  press         = 100.0
  press_conv_thr = 0.5
/

ATOMIC_SPECIES
  H        1.0080  H.pbesol-n-oncvpsp-pd.UPF
  Ir     192.2170  Ir.pbesol-spn-oncvpsp-pd.UPF
  Mg      24.3050  Mg.pbesol-spn-oncvpsp-pd.UPF

ATOMIC_POSITIONS crystal
  Ir       0.0000000000     0.0000000000     0.0000000000
  Mg       0.2500000000     0.2500000000     0.2500000000
  Mg       0.7500000000     0.7500000000     0.7500000000
  H        0.7550000000     0.2450000000     0.2450000000
  H        0.2450000000     0.7550000000     0.7550000000
  H        0.2450000000     0.7550000000     0.2450000000
  H        0.7550000000     0.2450000000     0.7550000000
  H        0.2450000000     0.2450000000     0.7550000000
  H        0.7550000000     0.7550000000     0.2450000000

K_POINTS automatic
  8 8 8  0 0 0

CELL_PARAMETERS angstrom
      0.0000000000     3.3100000000     3.3100000000
      3.3100000000     0.0000000000     3.3100000000
      3.3100000000     3.3100000000     0.0000000000
