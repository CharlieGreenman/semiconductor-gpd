! CONVENTION: PBEsol, ONCV PseudoDojo, pressure in kbar = GPa*10
! Target pressure: 10 GPa = 100.0 kbar
! ecutwfc = 80 Ry, ecutrho = 320 Ry
! Generated by screening/qe_templates.py
&CONTROL
  calculation  = 'vc-relax'
  prefix       = 'Ga'
  outdir       = './tmp'
  pseudo_dir   = './pseudo'
  tprnfor      = .true.
  tstress      = .true.
  forc_conv_thr = 1.0d-4
  etot_conv_thr = 1.0d-6
/

&SYSTEM
  ibrav        = 0
  nat          = 4
  ntyp         = 1
  ecutwfc      = 80
  ecutrho      = 320
  input_dft    = 'pbesol'
  occupations  = 'smearing'
  smearing     = 'mv'
  degauss      = 0.02
/

&ELECTRONS
  conv_thr     = 1.0d-8
  mixing_beta  = 0.3
/

&IONS
  ion_dynamics = 'bfgs'
/

&CELL
  cell_dynamics = 'bfgs'
  press         = 100.0
  press_conv_thr = 0.5
/

ATOMIC_SPECIES
  Ga      69.7230  Ga.pbesol-dn-oncvpsp-pd.UPF

ATOMIC_POSITIONS crystal
  Ga       0.8455000000     0.1545000000     0.0812000000
  Ga       0.6545000000     0.3455000000     0.5812000000
  Ga       0.3455000000     0.6545000000     0.4188000000
  Ga       0.1545000000     0.8455000000     0.9188000000

K_POINTS automatic
  6 6 6  0 0 0

CELL_PARAMETERS angstrom
      2.2593000000    -3.8285000000     0.0000000000
      2.2593000000     3.8285000000     0.0000000000
      0.0000000000     0.0000000000     4.5258000000
