! CONVENTION: PBEsol, ONCV PseudoDojo, pressure in kbar = GPa*10
! Target pressure: 5 GPa = 50.0 kbar
! ecutwfc = 80 Ry, ecutrho = 320 Ry
! Generated by screening/qe_templates.py
&CONTROL
  calculation  = 'vc-relax'
  prefix       = 'Rb'
  outdir       = './tmp'
  pseudo_dir   = './pseudo'
  tprnfor      = .true.
  tstress      = .true.
  forc_conv_thr = 1.0d-4
  etot_conv_thr = 1.0d-6
/

&SYSTEM
  ibrav        = 0
  nat          = 1
  ntyp         = 1
  ecutwfc      = 80
  ecutrho      = 320
  input_dft    = 'pbesol'
  occupations  = 'smearing'
  smearing     = 'mv'
  degauss      = 0.02
/

&ELECTRONS
  conv_thr     = 1.0d-8
  mixing_beta  = 0.3
/

&IONS
  ion_dynamics = 'bfgs'
/

&CELL
  cell_dynamics = 'bfgs'
  press         = 50.0
  press_conv_thr = 0.5
/

ATOMIC_SPECIES
  Rb      85.4678  Rb.pbesol-spn-oncvpsp-pd.UPF

ATOMIC_POSITIONS crystal
  Rb       0.0000000000     0.0000000000     0.0000000000

K_POINTS automatic
  6 6 6  0 0 0

CELL_PARAMETERS angstrom
     -2.8525000000     2.8525000000     2.8525000000
      2.8525000000    -2.8525000000     2.8525000000
      2.8525000000     2.8525000000    -2.8525000000
