  "verdict": {
    "track_B_status": "CLOSED_NEGATIVE",
    "reason": "d-wave Eliashberg gives LOWER Tc than Allen-Dynes because lambda_d < lambda_total while Z = 1+lambda_total",
    "Tc_aniso_base_K": 87.0,
    "Tc_AD_base_K": 197.0,
    "R_base": 0.442,
    "max_Tc_d_in_scan_K": 143.9,
    "reaches_300K_anywhere": false,
    "gap_to_300K_best_K": 156.1,
    "conclusion": "The full anisotropic d-wave Eliashberg with proper Z renormalization gives Tc = 87.0 K (baseline), with maximum 143.9 K in the parameter scan. 300 K is NOT reachable. The v12.0 Allen-Dynes baseline of 197 K was an overestimate because it used lambda_total rather than lambda_d for pairing. The 103 K gap cannot be closed by anisotropic effects."
  },
  "physical_insight": {
    "why_lower": "In d-wave, only ~64% of the total coupling (lambda_d/lambda_total) contributes to pairing. But 100% of the coupling contributes to mass renormalization (Z). This asymmetry fundamentally limits d-wave Tc.",
    "comparison_with_cuprates": "In cuprates, the 'anisotropic enhancement' typically refers to the effect within the d-wave channel (comparing anisotropic vs averaged d-wave coupling). This is a modest 10-30% effect. What we computed here is the d-wave Eliashberg Tc vs the isotropic Allen-Dynes Tc, which shows a large REDUCTION because of the lambda_d vs lambda_total mismatch.",
    "allen_dynes_overestimate": "Allen-Dynes with mu*=0 and lambda_total implicitly assumes all coupling pairs in the same channel. For d-wave, this is wrong -- only the d-wave projected fraction contributes."
  },
