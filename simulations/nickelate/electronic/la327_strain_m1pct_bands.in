! La3Ni2O7 bands at -1.20% strain (LAO). Phase 29-02.
! Same high-symmetry path as unstrained for direct comparison.

&CONTROL
   calculation = 'bands', prefix = 'la327_m1pct'
   outdir = './tmp/', pseudo_dir = './pseudo/', verbosity = 'high'
/
&SYSTEM
   ibrav = 0, nat = 24, ntyp = 3
   ecutwfc = 80.0, ecutrho = 640.0
   occupations = 'smearing', smearing = 'mv', degauss = 0.02
   nspin = 1, nbnd = 180
/
&ELECTRONS
   conv_thr = 1.0d-10, diagonalization = 'david'
/
ATOMIC_SPECIES
   La 138.90547 La_ONCV_PBEsol-1.2.upf
   Ni  58.6934  Ni_ONCV_PBEsol-1.2.upf
   O   15.9994  O_ONCV_PBEsol-1.2.upf

