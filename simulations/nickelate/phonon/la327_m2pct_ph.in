! La3Ni2O7 DFPT phonon at -2.01% strain (SLAO). Phase 29-03.
! Same parameters as 0% for fair comparison.

&INPUTPH
   prefix       = 'la327_m2pct'
   outdir       = './tmp/'
   fildyn       = 'la327_m2pct.dyn'
   tr2_ph       = 1.0d-14
   alpha_mix(1) = 0.3
   ldisp        = .true.
   nq1 = 4, nq2 = 4, nq3 = 1
   recover      = .true.
/
