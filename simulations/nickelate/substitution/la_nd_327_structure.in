! ASSERT_CONVENTION: strain_sign=negative_compressive, functional=PBEsol

! ============================================================================
! (La2Nd)Ni2O7 -- ordered Nd substitution on SLAO substrate (-2.01% strain)
! Phase 29-04, Task 1
!
! Nd3+: 4f^3 configuration, ionic radius 1.109 A (vs La3+ = 1.160 A)
! Chemical pressure: ~4-6 GPa equivalent
! Same structure template as Pr; replace Pr with Nd
! ============================================================================

&CONTROL
   calculation  = 'vc-relax'
   prefix       = 'la2nd_m2pct'
   outdir       = './tmp/'
   pseudo_dir   = './pseudo/'
   tstress      = .true.
   tprnfor      = .true.
   forc_conv_thr = 1.0d-4
   etot_conv_thr = 1.0d-6
   nstep        = 200
   verbosity    = 'high'
/

&SYSTEM
   ibrav        = 0
   nat          = 24
   ntyp         = 4
   ecutwfc      = 80.0
   ecutrho      = 640.0
   occupations  = 'smearing'
   smearing     = 'mv'
   degauss      = 0.02
   nspin        = 1
/

&ELECTRONS
   conv_thr     = 1.0d-8
   mixing_beta  = 0.3
   diagonalization = 'david'
   electron_maxstep = 200
/

&IONS
   ion_dynamics = 'bfgs'
/

&CELL
   cell_dynamics = 'bfgs'
   cell_dofree  = 'z'
   press        = 0.0
   press_conv_thr = 0.5
/

ATOMIC_SPECIES
   La  138.90547  La_ONCV_PBEsol-1.2.upf
   Nd  144.242    Nd_ONCV_PBEsol-1.2.upf
   Ni   58.6934   Ni_ONCV_PBEsol-1.2.upf
   O    15.9994   O_ONCV_PBEsol-1.2.upf

CELL_PARAMETERS {angstrom}
   3.756000000   0.000000000   0.000000000
   0.000000000   3.756000000   0.000000000
   0.000000000   0.000000000  21.000000000

ATOMIC_POSITIONS {crystal}
   La   0.000000   0.000000   0.500000
   La   0.500000   0.500000   0.000000
   Nd   0.000000   0.000000   0.318000
   Nd   0.000000   0.000000   0.682000
   La   0.500000   0.500000   0.818000
   La   0.500000   0.500000   0.182000
   Ni   0.000000   0.000000   0.098000
   Ni   0.000000   0.000000   0.902000
   Ni   0.500000   0.500000   0.598000
   Ni   0.500000   0.500000   0.402000
   O    0.000000   0.000000   0.000000
   O    0.500000   0.500000   0.500000
   O    0.000000   0.000000   0.198000
   O    0.000000   0.000000   0.802000
   O    0.500000   0.500000   0.698000
   O    0.500000   0.500000   0.302000
   O    0.000000   0.500000   0.098000
   O    0.500000   0.000000   0.098000
   O    0.000000   0.500000   0.902000
   O    0.500000   0.000000   0.902000
   O    0.500000   0.000000   0.598000
   O    0.000000   0.500000   0.598000
   O    0.500000   0.000000   0.402000
   O    0.000000   0.500000   0.402000

K_POINTS {automatic}
   8 8 2   1 1 1
