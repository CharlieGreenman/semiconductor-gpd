! ASSERT_CONVENTION: natural_units=explicit_hbar_kB, fourier_convention=QE_planewave
!
! HgBa2Ca2Cu3O8+delta (Hg1223) -- EPW electron-phonon coupling
!
! Prerequisites:
!   1. Converged SCF (hg1223_scf.in, Plan 27-01)
!   2. NSCF on coarse k-grid matching nk1,nk2,nk3 below
!   3. Completed DFPT phonon calculation (hg1223_ph.in) on nq1,nq2,nq3
!
! This input performs:
!   1. Wannierization of the electronic structure near E_F
!   2. Wannier interpolation of electron-phonon matrix elements
!   3. Computation of alpha2F(omega), lambda, omega_log on fine grids
!
! IMPORTANT: EPW requires a SEPARATE nscf calculation on the COARSE k-grid
!   (8x8x4 here, NOT the dense 16x16x8 used for DOS in Plan 27-01).
!   The coarse nscf must use nosym=.true. and noinv=.true.
!
! Wannier function setup:
!   Cu has 5 d-orbitals; O has 3 p-orbitals.
!   3 Cu atoms: 15 d-projections
!   8 O atoms:  24 p-projections
!   Total: 39 Wannier functions
!   This captures the full Cu-d / O-p antibonding manifold at E_F.
!
! Disentanglement windows:
!   Frozen window: E_F +/- 2 eV (captures all Fermi surface bands)
!   Outer window:  E_F +/- 6 eV (provides enough variational freedom)
!   E_F for Hg1223 ~ 10-12 eV (PBEsol; exact value from SCF output)
!
! CONVERGENCE TEST PLAN:
!   Grid A: nkf=20,20,10  nqf=20,20,10  (production)
!   Grid B: nkf=30,30,15  nqf=30,30,15  (validation)
!   Criterion: |lambda_A - lambda_B| / lambda_B < 0.001 (3 sig figs)
!
! EXPECTED WALL TIME: Grid A ~4-8 hrs on 64 cores; Grid B ~12-24 hrs

--
&inputepw
  prefix       = 'hg1223'
  outdir       = './tmp/'
  dvscf_dir    = './save/'

  ! ---- Coarse grids (must match NSCF and DFPT) ----
  nk1          = 8
  nk2          = 8
  nk3          = 4
  nq1          = 4
  nq2          = 4
  nq3          = 2

  ! ---- Fine interpolation grids ----
  ! Grid A (production): 20x20x10
  nkf1         = 20
  nkf2         = 20
  nkf3         = 10
  nqf1         = 20
  nqf2         = 20
  nqf3         = 10

  ! ---- Wannierization parameters ----
  ! Projections: Cu-d + O-p (set via projections block below)
  num_iter     = 500
  dis_num_iter = 200
  proj_natom   = 11

  ! Disentanglement windows (eV, relative to Fermi level)
  ! Set dis_win_min/max and dis_froz_min/max AFTER obtaining E_F from SCF
  ! Placeholder values assuming E_F ~ 11 eV:
  dis_win_min  = 5.0
  dis_win_max  = 17.0
  dis_froz_min = 9.0
  dis_froz_max = 13.0

  ! ---- Electron-phonon calculation ----
  ephwrite     = .true.
  epbwrite     = .true.
  epbread      = .false.

  ! ---- Output controls ----
  elph         = .true.
  a2f          = .true.
  fsthick      = 1.0        ! eV -- Fermi surface thickness for delta functions
  degaussw     = 0.025      ! eV -- Gaussian broadening for delta(E_nk - E_F)
  degaussq     = 0.05       ! meV -- Gaussian broadening for phonon delta functions
  nstemp       = 1
  temps        = 300.0      ! K -- temperature for Fermi-Dirac smearing

  ! ---- Wannier function convergence ----
  wannierize   = .true.
  auto_projections = .false.

  ! ---- Symmetry ----
  use_ws       = .true.     ! Wigner-Seitz cell for BZ integration

  ! ---- Output files ----
  ! EPW writes: prefix.a2f, prefix.lambda, prefix.phdos_proj
  ! These are parsed by epw_convergence.py
/

! ---- Wannier projections ----
! Format: atom_index : orbital_type
! Cu atoms (indices 6, 7, 8 in the 16-atom cell): d orbitals
! O atoms (indices 9-16): p orbitals
! NOTE: Actual atom indices depend on the order in ATOMIC_POSITIONS.
!       The numbering below matches hg1223_scf.in ordering.

PROJECTIONS
Cu : d
O  : p
END

! ---- NSCF input template for EPW coarse grid ----
! EPW requires a SEPARATE nscf.x run on the coarse k-grid WITH:
!   nosym = .true.
!   noinv = .true.
! This is different from the NSCF in Plan 27-01 (which used 16x16x8 for DOS).
! Save this as hg1223_nscf_epw.in:
!
! &CONTROL
!   calculation = 'nscf'
!   prefix      = 'hg1223'
!   outdir      = './tmp/'
!   pseudo_dir  = './pseudo/'
! /
! &SYSTEM
!   ibrav       = 0
!   nat         = 16
!   ntyp        = 5
!   ecutwfc     = 80.0
!   ecutrho     = 320.0
!   input_dft   = 'pbesol'
!   occupations = 'smearing'
!   smearing    = 'cold'
!   degauss     = 0.02
!   nspin       = 1
!   nosym       = .true.
!   noinv       = .true.
!   nbnd        = 60
! /
! &ELECTRONS
!   conv_thr    = 1.0d-10
! /
! K_POINTS {crystal}
!   [generated by kmesh.pl 8 8 4 or EPW utility]
!
! EXPECTED PHYSICS:
!   lambda ~ 1.0-2.5 (moderate to strong coupling for a cuprate)
!   omega_log ~ 200-500 K (25-43 meV)
!   alpha2F peaks at Cu-O stretching frequencies (40-70 meV)
!   N(E_F) per spin ~ 2.0 states/eV/spin/cell (from Plan 27-01)
!
! DIAGNOSTIC NOTE:
!   If lambda < 0.5, phonon-mediated pairing alone cannot explain Tc ~ 151 K.
!   This is NOT a pipeline failure but a physically meaningful finding that
!   Hg1223 likely requires beyond-Eliashberg pairing (spin fluctuations).
!   Document this and note Eliashberg Tc will systematically underestimate.
!
! MIGDAL CHECK (must pass before trusting Eliashberg):
!   omega_log / E_F < 0.1
!   For Hg1223: omega_log ~ 30 meV, E_F ~ 2 eV from band bottom -> ratio ~ 0.015
!   Migdal theorem expected to hold comfortably.
