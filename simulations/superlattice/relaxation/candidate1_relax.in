! ASSERT_CONVENTION: natural_units=explicit_hbar_kB, fourier_convention=QE_planewave
!
! Candidate 1: [HgBa2CuO4]_1/[LaNiO2]_1, ~12 atoms, a~3.92, c~12.9
! Superlattice vc-relax: PBEsol + ONCV (following Phase 27 conventions)
! Structure from Plan 30-01 CIF: hgba2cuo4_lanio2_superlattice.cif
!
! APPROXIMATIONS:
!   1. PBEsol GGA -- good for structural properties of oxides
!   2. Scalar-relativistic ONCV -- SOC omitted (small near E_F for Cu/Ni)
!   3. nspin=1 -- non-magnetic starting point
!   4. ecutwfc=90 Ry -- higher than Hg1223 (80 Ry) due to mixed chemistry
!
! NOTE: This input is prepared for HPC execution. Not runnable locally.

&CONTROL
  calculation  = 'vc-relax'
  prefix       = 'sl_cand1'
  outdir       = './tmp/'
  pseudo_dir   = './pseudo/'
  tstress      = .true.
  tprnfor      = .true.
  forc_conv_thr = 1.0d-4
  etot_conv_thr = 1.0d-6
  verbosity    = 'high'
/

&SYSTEM
  ibrav        = 0
  nat          = 12
  ntyp         = 6
  ecutwfc      = 90.0
  ecutrho      = 360.0
  input_dft    = 'pbesol'
  occupations  = 'smearing'
  smearing     = 'cold'
  degauss      = 0.02
  nspin        = 1
/

&ELECTRONS
  conv_thr     = 1.0d-8
  mixing_beta  = 0.3
  mixing_mode  = 'plain'
  diagonalization = 'david'
  electron_maxstep = 300
/

&IONS
  ion_dynamics = 'bfgs'
/

&CELL
  cell_dynamics = 'bfgs'
  cell_dofree  = 'all'
  press        = 0.0
  press_conv_thr = 0.1
/

ATOMIC_SPECIES
  Ba    137.327   Ba_ONCV_PBEsol-1.2.upf
  Cu     63.546   Cu_ONCV_PBEsol-1.2.upf
  Hg    200.590   Hg_ONCV_PBEsol-1.2.upf
  La    138.905   La_ONCV_PBEsol-1.2.upf
  Ni     58.693   Ni_ONCV_PBEsol-1.2.upf
  O      15.999   O_ONCV_PBEsol-1.2.upf

CELL_PARAMETERS {angstrom}
      3.918500      0.000000      0.000000
     -0.000000      3.918500      0.000000
      0.000000      0.000000     12.882000

ATOMIC_POSITIONS {crystal}
  Ba      0.500000      0.500000      0.478746
  Ba      0.500000      0.500000      0.783247
  La      0.500000      0.500000      0.130997
  Cu      0.000000      0.000000      0.630997
  Ni      0.000000      0.000000      0.000000
  Hg      0.000000      0.000000      0.261993
  O       0.500000      0.000000      0.000000
  O       0.000000      0.500000      0.000000
  O       0.500000      0.000000      0.630997
  O       0.000000      0.500000      0.630997
  O       0.000000      0.000000      0.379632
  O       0.000000      0.000000      0.882362

K_POINTS {automatic}
  8 8 4  0 0 0
