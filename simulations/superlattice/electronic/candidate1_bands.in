! Candidate 1 bands -- high-symmetry k-path

&CONTROL
  calculation  = 'bands'
  prefix       = 'sl_cand1'
  outdir       = './tmp/'
  pseudo_dir   = './pseudo/'
  verbosity    = 'high'
/

