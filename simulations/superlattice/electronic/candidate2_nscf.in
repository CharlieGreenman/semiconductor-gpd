! Candidate 2 NSCF -- dense k-grid for DOS (tetrahedra)

&CONTROL
  calculation  = 'nscf'
  prefix       = 'sl_cand2'
  outdir       = './tmp/'
  pseudo_dir   = './pseudo/'
  verbosity    = 'high'
/

&SYSTEM
  ibrav        = 0
  nat          = 40
  ntyp         = 7
  ecutwfc      = 90.0
  ecutrho      = 360.0
  input_dft    = 'pbesol'
  occupations  = 'tetrahedra_opt'
  nspin        = 1
  nbnd         = 181
/

&ELECTRONS
  conv_thr     = 1.0d-8
/

