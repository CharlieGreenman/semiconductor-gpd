! RbInH3 Pm-3m SCF calculation at 10 GPa (using relaxed structure)
! ASSERT_CONVENTION: natural_units=NOT_used, fourier_convention=QE_plane_wave, unit_system_internal=Rydberg_atomic, xc_functional=PBEsol, pseudopotential=ONCV_norm_conserving
!
! Run AFTER vc-relax: update celldm(1) with relaxed lattice parameter.
! Purpose: Generate converged charge density for NSCF and DFPT.
!
! Expected relaxed lattice parameter: a ~ 3.75-3.85 A at 10 GPa
! Reference: Du et al. (2024) for RbInH3 at low pressure

&CONTROL
  calculation  = 'scf'
  prefix       = 'rbinh3'
  outdir       = './tmp/'
  pseudo_dir   = './pseudo/'
  tprnfor      = .true.
  tstress      = .true.
  verbosity    = 'high'
/

&SYSTEM
  ibrav        = 1            ! Simple cubic (Pm-3m)
  celldm(1)    = 7.21614      ! UPDATE with relaxed value from vc-relax
  nat          = 5
  ntyp         = 3
  ecutwfc      = 90.0         ! Ry
  ecutrho      = 360.0        ! Ry
  occupations  = 'smearing'
  smearing     = 'mp'
  degauss      = 0.02         ! Ry
/

&ELECTRONS
  conv_thr     = 1.0d-10      ! Tight for phonon-quality charge density
  mixing_beta  = 0.3
  diagonalization = 'david'
/

ATOMIC_SPECIES
  Rb  85.4678  Rb.upf
  In  114.818  In.upf
  H    1.008   H.upf

ATOMIC_POSITIONS {crystal}
  Rb  0.000000  0.000000  0.000000
  In  0.500000  0.500000  0.500000
  H   0.500000  0.500000  0.000000
  H   0.500000  0.000000  0.500000
  H   0.000000  0.500000  0.500000

K_POINTS {automatic}
  12  12  12  0  0  0
