! KGaH3 2x2x2 supercell SCF - config 0
! ASSERT_CONVENTION: natural_units=NOT_used, unit_system_internal=Rydberg_atomic,
!   pressure_unit_qe=kbar, xc_functional=PBEsol, pseudopotential=ONCV_norm_conserving
! Pressure: 10.0 GPa = 100.0 kbar
! Supercell: 2x2x2, 40 atoms
! Dimensional check: ecutwfc = 80.0 Ry = 1088.5 eV

&CONTROL
  calculation  = 'scf'
  prefix       = 'kgah3_sc_0000'
  outdir       = './tmp/'
  pseudo_dir   = './pseudo/'
  tprnfor      = .true.
  tstress      = .true.
/

&SYSTEM
  ibrav        = 1
  celldm(1)    = 14.054480
  nat          = 40
  ntyp         = 3
  ecutwfc      = 80.0
  ecutrho      = 640.0
  occupations  = 'smearing'
  smearing     = 'mp'
  degauss      = 0.02
/

&ELECTRONS
  conv_thr     = 1e-08
  mixing_beta  = 0.3
  mixing_mode  = 'plain'
  diagonalization = 'david'
/

ATOMIC_SPECIES
  K        39.098  K.upf
  Ga       69.723  Ga.upf
  H         1.008  H.upf

ATOMIC_POSITIONS {crystal}
  K      0.0000000000   0.0000000000   0.0000000000
