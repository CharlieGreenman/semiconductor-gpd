! KGaH3 Pm-3m variable-cell relaxation at 10 GPa
! ASSERT_CONVENTION: natural_units=NOT_used, fourier_convention=QE_plane_wave, unit_system_internal=Rydberg_atomic, pressure_unit_qe=kbar, xc_functional=PBEsol, pseudopotential=ONCV_norm_conserving
!
! Structure: Pm-3m (space group #221), simple cubic perovskite
!   K  at 1a: (0, 0, 0)
!   Ga at 1b: (0.5, 0.5, 0.5)
!   H  at 3d: (0.5, 0.5, 0), (0.5, 0, 0.5), (0, 0.5, 0.5)
!   5 atoms per unit cell
!
! Target pressure: 10 GPa = 100 kbar
! Initial lattice parameter: a ~ 3.72 A (will be optimized)
!   K is smaller than Rb, Ga smaller than In -> smaller cell expected
!
! Pseudopotentials: ONCV PseudoDojo PBEsol stringent
! Reference: Du et al., Adv. Sci. 11, 2408370 (2024) -- Tc = 146 K at 10 GPa
! Note: This is a DIRECT pressure comparison (same 10 GPa)
! Note: E_hull = 37.5 meV/atom (highest of 3 candidates; closest to stability threshold)

&CONTROL
  calculation  = 'vc-relax'
  prefix       = 'kgah3'
  outdir       = './tmp/'
  pseudo_dir   = './pseudo/'
  tprnfor      = .true.
  tstress      = .true.
  forc_conv_thr = 1.0d-4
  etot_conv_thr = 1.0d-6
  nstep        = 200
/

&SYSTEM
  ibrav        = 1            ! Simple cubic
  celldm(1)    = 7.02724      ! a = 3.72 A = 7.02724 Bohr (initial guess)
  nat          = 5
  ntyp         = 3
  ecutwfc      = 90.0         ! Ry (Phase 3 standard)
  ecutrho      = 360.0        ! Ry (4x ecutwfc for NC PPs)
  occupations  = 'smearing'
  smearing     = 'mp'
  degauss      = 0.02         ! Ry
/

&ELECTRONS
  conv_thr     = 1.0d-10
  mixing_beta  = 0.3
  mixing_mode  = 'plain'
  diagonalization = 'david'
/

&IONS
  ion_dynamics = 'bfgs'
/

&CELL
  cell_dynamics = 'bfgs'
  press        = 100.0        ! 10 GPa = 100 kbar
  press_conv_thr = 0.5
  cell_dofree  = 'ibrav'
/

ATOMIC_SPECIES
  K   39.0983  K.upf         ! PseudoDojo PBEsol ONCV NC
  Ga  69.723   Ga.upf        ! PseudoDojo PBEsol ONCV NC
  H    1.008   H.upf         ! PseudoDojo PBEsol ONCV NC

ATOMIC_POSITIONS {crystal}
  K   0.000000  0.000000  0.000000
  Ga  0.500000  0.500000  0.500000
  H   0.500000  0.500000  0.000000
  H   0.500000  0.000000  0.500000
  H   0.000000  0.500000  0.500000

K_POINTS {automatic}
  12  12  12  0  0  0
