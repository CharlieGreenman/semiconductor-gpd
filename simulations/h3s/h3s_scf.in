! H3S Im-3m SCF calculation at 150 GPa (using relaxed structure)
! ASSERT_CONVENTION: natural_units=NOT_used, fourier_convention=QE_plane_wave, unit_system_internal=Rydberg_atomic, xc_functional=PBEsol, pseudopotential=ONCV_norm_conserving
!
! Run AFTER vc-relax: update celldm(1) with relaxed lattice parameter.
! Purpose: Generate converged charge density for NSCF and DFPT.
!
! Expected relaxed lattice parameter: a_conv ~ 3.00-3.10 A at 150 GPa
! Reference: Einaga et al. (2016): a = 3.10 A at 140 GPa

&CONTROL
  calculation  = 'scf'
  prefix       = 'h3s'
  outdir       = './tmp/'
  pseudo_dir   = './pseudo/'
  tprnfor      = .true.
  tstress      = .true.
  verbosity    = 'high'
/

&SYSTEM
  ibrav        = 3           ! BCC primitive cell
  celldm(1)    = 5.66918     ! UPDATE with relaxed value from vc-relax
  nat          = 4
  ntyp         = 2
  ecutwfc      = 100.0       ! Ry (from convergence test)
  ecutrho      = 400.0       ! Ry
  occupations  = 'smearing'
  smearing     = 'mp'
  degauss      = 0.02        ! Ry
/

&ELECTRONS
  conv_thr     = 1.0d-10     ! Tight for phonon-quality charge density
  mixing_beta  = 0.3
  diagonalization = 'david'
/

ATOMIC_SPECIES
  S   32.065  S.upf
  H    1.008  H.upf

ATOMIC_POSITIONS {crystal}
  S   0.000000  0.000000  0.000000
  H   0.500000  0.500000  0.000000
  H   0.500000  0.000000  0.500000
  H   0.000000  0.500000  0.500000

K_POINTS {automatic}
  24  24  24  0  0  0
